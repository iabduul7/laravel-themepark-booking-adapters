{
    "name": "iabduul7/laravel-themepark-booking-adapters",
    "description": "Self-contained, drop-in Laravel booking adapters for Walt Disney World & SeaWorld/United Parks (Redeam) and Universal Orlando (SmartOrder): catalog, pricing, availability, holds/bookings, orders and voucher data.",
    "keywords": [
        "iabduul7",
        "laravel",
        "booking",
        "theme-park",
        "redeam",
        "smartorder",
        "adapters",
        "tickets"
    ],
    "homepage": "https://github.com/iabduul7/laravel-themepark-booking-adapters",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdullah",
            "email": "contact@abdullah.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.15",
        "illuminate/contracts": "^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "brianium/paratest": "^7.4",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5.3|^12.0",
        "spatie/laravel-ray": "^1.32"
    },
    "autoload": {
        "psr-4": {
            "Iabduul7\\ThemeParkAdapters\\": "src",
            "Iabduul7\\ThemeParkAdapters\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Iabduul7\\ThemeParkAdapters\\Tests\\": "tests"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer validate --strict",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "test": "vendor/bin/phpunit",
        "test:adapters": "vendor/bin/phpunit tests/Adapters",
        "test:coverage": "vendor/bin/phpunit --coverage-text --coverage-clover=build/logs/clover.xml",
        "test:coverage-html": "vendor/bin/phpunit --coverage-html=build/coverage",
        "test:parallel": "vendor/bin/paratest --processes=4 --cache-directory=/tmp/paratest-cache --no-coverage",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --test",
        "quality": "vendor/bin/pint --test && vendor/bin/phpstan analyse --memory-limit=1G && vendor/bin/phpunit tests/Adapters",
        "quality:fix": "vendor/bin/pint && vendor/bin/phpunit tests/Adapters",
        "hooks:install": "npx simple-git-hooks",
        "hooks:uninstall": "git config --unset-all core.hooksPath || true",
        "refactor": "vendor/bin/rector process"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Iabduul7\\ThemeParkAdapters\\ThemeParkAdaptersServiceProvider"
            ],
            "aliases": {
                "ThemePark": "Iabduul7\\ThemeParkAdapters\\Facades\\ThemePark"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
