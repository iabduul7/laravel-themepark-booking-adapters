<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.5/phpunit.xsd"
    backupGlobals="false"
    backupStaticProperties="false"
    bootstrap="vendor/autoload.php"
    colors="true"
    processIsolation="false"
    stopOnFailure="false"
    executionOrder="random"
    failOnWarning="true"
    failOnRisky="true"
    failOnEmptyTestSuite="true"
    beStrictAboutOutputDuringTests="true"
    cacheDirectory=".phpunit.cache"
>
    <testsuites>
        <testsuite name="Theme Park Adapters Test Suite">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
    <!--
        Coverage scope only. Reports are NOT forced here: a plain `composer test`
        run must not attempt coverage, otherwise jobs without a driver
        (coverage: none) emit "No code coverage driver available", which
        failOnWarning turns into a CI failure. The coverage leg requests reports
        explicitly via flags in the `test:coverage` script (with pcov enabled).
    -->
    <source>
        <include>
            <directory suffix=".php">./src</directory>
        </include>
    </source>
</phpunit>
